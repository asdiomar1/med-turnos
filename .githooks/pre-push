#!/usr/bin/env sh
set -eu

REPO_ROOT="$(git rev-parse --show-toplevel)"
SCRIPT_PATH="$REPO_ROOT/scripts/ci/pre-push-quality.ps1"

if [ ! -f "$SCRIPT_PATH" ]; then
  echo "No se encontró $SCRIPT_PATH"
  exit 1
fi

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File "$SCRIPT_PATH"
elif command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -ExecutionPolicy Bypass -File "$SCRIPT_PATH"
else
  echo "No se encontró pwsh/powershell para ejecutar pre-push-quality.ps1"
  exit 1
fi
